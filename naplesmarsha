<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=Jost:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --sand: #E8DDD0;
    --sand-light: #F4EFE9;
    --sand-dark: #C9BAA8;
    --gulf: #4A7C8E;
    --gulf-deep: #2E5A6B;
    --gulf-light: #7AAFC0;
    --gulf-pale: #D4E8EF;
    --palm: #4A6741;
    --white: #FDFAF7;
    --ink: #1C2B2E;
    --ink-mid: #3D5055;
    --ink-light: #6B8086;
    --border: rgba(74,124,142,0.2);
    --shadow: 0 4px 32px rgba(28,43,46,0.08);
  }
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }
  body { font-family: 'Jost', sans-serif; background: var(--sand-light); color: var(--ink); line-height: 1.6; overflow-x: hidden; }

  header { position: relative; background: var(--ink); overflow: hidden; min-height: 420px; display: flex; flex-direction: column; justify-content: flex-end; }
  .header-bg { position: absolute; inset: 0; background: radial-gradient(ellipse 60% 40% at 80% 60%, rgba(74,124,142,0.35) 0%, transparent 70%), radial-gradient(ellipse 40% 60% at 20% 80%, rgba(74,103,65,0.2) 0%, transparent 60%), linear-gradient(160deg, #1C2B2E 0%, #2E3F44 50%, #1C2B2E 100%); }
  .wave-pattern { position: absolute; bottom: 0; left: 0; right: 0; height: 120px; opacity: 0.06; background-image: repeating-linear-gradient(0deg, transparent, transparent 18px, rgba(74,124,142,1) 18px, rgba(74,124,142,1) 19px), repeating-linear-gradient(90deg, transparent, transparent 80px, rgba(74,124,142,0.4) 80px, rgba(74,124,142,0.4) 81px); }
  .header-content { position: relative; z-index: 2; padding: 60px 60px 50px; }
  .realtor-badge { display: inline-flex; align-items: center; gap: 10px; background: rgba(74,124,142,0.2); border: 1px solid rgba(74,124,142,0.4); border-radius: 2px; padding: 6px 14px; margin-bottom: 24px; font-size: 11px; font-weight: 500; letter-spacing: 0.15em; text-transform: uppercase; color: var(--gulf-light); }
  .realtor-badge::before { content: ''; display: block; width: 6px; height: 6px; border-radius: 50%; background: var(--gulf-light); }
  header h1 { font-family: 'Cormorant Garamond', serif; font-size: clamp(36px, 5vw, 64px); font-weight: 300; color: var(--white); line-height: 1.1; margin-bottom: 12px; }
  header h1 em { font-style: italic; color: var(--gulf-light); }
  header .subtitle { font-size: 14px; font-weight: 300; color: rgba(253,250,247,0.55); letter-spacing: 0.05em; margin-bottom: 40px; }
  .header-stats { display: flex; gap: 40px; border-top: 1px solid rgba(255,255,255,0.1); padding-top: 28px; flex-wrap: wrap; }
  .hstat-val { font-family: 'Cormorant Garamond', serif; font-size: 28px; font-weight: 400; color: var(--white); line-height: 1; }
  .hstat-label { font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase; color: rgba(253,250,247,0.4); margin-top: 4px; }

  nav { position: sticky; top: 0; z-index: 100; background: var(--white); border-bottom: 1px solid var(--border); display: flex; justify-content: space-between; align-items: center; padding: 0 60px; height: 56px; box-shadow: 0 2px 16px rgba(28,43,46,0.06); }
  .nav-tabs { display: flex; height: 100%; }
  .nav-tab { font-size: 12px; font-weight: 500; letter-spacing: 0.08em; text-transform: uppercase; color: var(--ink-light); background: none; border: none; border-bottom: 2px solid transparent; padding: 0 20px; cursor: pointer; height: 100%; transition: all 0.2s; }
  .nav-tab:hover { color: var(--gulf); }
  .nav-tab.active { color: var(--gulf-deep); border-bottom-color: var(--gulf); }
  .nav-realtor { font-size: 12px; color: var(--ink-light); font-weight: 300; }
  .nav-realtor strong { color: var(--gulf-deep); font-weight: 500; }

  main { max-width: 1400px; margin: 0 auto; padding: 0 60px 80px; }
  section { display: none; padding-top: 48px; }
  section.active { display: block; }

  .section-intro { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 32px; gap: 20px; flex-wrap: wrap; }
  .section-intro h2 { font-family: 'Cormorant Garamond', serif; font-size: 32px; font-weight: 400; color: var(--ink); }
  .section-intro h2 span { font-style: italic; color: var(--gulf); }
  .section-intro p { font-size: 13px; color: var(--ink-light); font-weight: 300; max-width: 420px; text-align: right; }

  .neighborhood-divider { display: flex; align-items: center; gap: 16px; margin: 40px 0 24px; }
  .neighborhood-divider h3 { font-size: 10px; font-weight: 500; letter-spacing: 0.18em; text-transform: uppercase; color: var(--ink-light); white-space: nowrap; }
  .neighborhood-divider::after { content: ''; flex: 1; height: 1px; background: var(--border); }

  .prop-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 20px; }
  .prop-card { background: var(--white); border: 1px solid var(--border); border-radius: 4px; overflow: hidden; transition: transform 0.2s, box-shadow 0.2s; position: relative; }
  .prop-card:hover { transform: translateY(-3px); box-shadow: var(--shadow); }
  .prop-card.top-pick { border-color: var(--gulf); border-width: 2px; }

  .card-header { padding: 20px 20px 16px; border-bottom: 1px solid var(--border); position: relative; }
  .card-badge { display: inline-block; font-size: 9px; font-weight: 500; letter-spacing: 0.12em; text-transform: uppercase; padding: 3px 9px; border-radius: 2px; margin-bottom: 10px; }
  .badge-new { background: #E1F0E8; color: #3A6B42; }
  .badge-recent { background: #D4E8EF; color: #2E5A6B; }
  .badge-resale { background: #EDE8E3; color: #6B5A48; }
  .badge-top { background: var(--gulf); color: var(--white); }
  .card-address { font-family: 'Cormorant Garamond', serif; font-size: 20px; font-weight: 500; color: var(--ink); margin-bottom: 3px; }
  .card-neighborhood { font-size: 11px; color: var(--ink-light); font-weight: 300; }
  .card-price { font-family: 'Cormorant Garamond', serif; font-size: 26px; font-weight: 400; color: var(--gulf-deep); margin-top: 14px; }
  .top-pick-ribbon { position: absolute; top: 16px; right: 16px; background: var(--gulf); color: white; font-size: 9px; font-weight: 500; letter-spacing: 0.1em; text-transform: uppercase; padding: 4px 10px; border-radius: 2px; }

  .card-body { padding: 16px 20px; }
  .metrics-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px 16px; margin-bottom: 16px; }
  .metric-label { font-size: 9px; font-weight: 500; letter-spacing: 0.1em; text-transform: uppercase; color: var(--ink-light); margin-bottom: 2px; }
  .metric-value { font-size: 13px; font-weight: 500; color: var(--ink); }
  .metric-value.highlight { color: var(--gulf-deep); }

  .psf-bar { margin: 0 0 14px; padding: 12px 14px; background: var(--sand-light); border-radius: 3px; border-left: 3px solid var(--gulf-light); }
  .psf-bar.best { border-left-color: var(--palm); }
  .psf-bar.high { border-left-color: var(--sand-dark); }
  .psf-label { font-size: 10px; color: var(--ink-light); letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 4px; }
  .psf-value { font-family: 'Cormorant Garamond', serif; font-size: 22px; font-weight: 500; color: var(--ink); }
  .psf-note { font-size: 10px; color: var(--ink-light); margin-top: 2px; }

  .amenities-block { margin: 0 0 14px; padding: 14px; background: var(--gulf-pale); border-radius: 3px; }
  .amenities-title { font-size: 9px; font-weight: 500; letter-spacing: 0.14em; text-transform: uppercase; color: var(--gulf-deep); margin-bottom: 10px; }
  .amenity-item { display: flex; align-items: center; gap: 8px; margin-bottom: 6px; font-size: 11px; }
  .amenity-icon { flex-shrink: 0; width: 18px; text-align: center; }
  .amenity-name { color: var(--ink-mid); flex: 1; }
  .amenity-dist { font-weight: 500; color: var(--gulf-deep); font-size: 10px; background: rgba(74,124,142,0.15); padding: 1px 7px; border-radius: 10px; white-space: nowrap; }

  .intangibles { border-top: 1px solid var(--border); padding-top: 14px; }
  .intangible-title { font-size: 9px; font-weight: 500; letter-spacing: 0.12em; text-transform: uppercase; color: var(--ink-light); margin-bottom: 10px; }
  .int-item { display: flex; justify-content: space-between; align-items: flex-start; gap: 8px; margin-bottom: 7px; font-size: 11px; }
  .int-key { color: var(--ink-light); flex-shrink: 0; }
  .int-val { text-align: right; }
  .int-val.pos { color: var(--palm); }
  .int-val.neg { color: #8B6914; }
  .int-val.neutral { color: var(--ink-mid); }

  .score-row { display: flex; align-items: center; gap: 10px; margin-top: 14px; padding-top: 12px; border-top: 1px solid var(--border); }
  .score-label { font-size: 10px; color: var(--ink-light); letter-spacing: 0.06em; text-transform: uppercase; flex-shrink: 0; }
  .score-track { flex: 1; height: 3px; background: var(--sand-dark); border-radius: 2px; }
  .score-fill { height: 100%; border-radius: 2px; background: var(--gulf); }
  .score-num { font-size: 12px; font-weight: 500; color: var(--ink-mid); }

  .chart-container { background: var(--white); border: 1px solid var(--border); border-radius: 4px; padding: 32px 40px; }
  .chart-title { font-family: 'Cormorant Garamond', serif; font-size: 24px; font-weight: 400; color: var(--ink); margin-bottom: 6px; }
  .chart-sub { font-size: 12px; color: var(--ink-light); font-weight: 300; margin-bottom: 32px; }
  .bar-chart { display: flex; flex-direction: column; gap: 14px; }
  .bar-row { display: flex; align-items: center; gap: 14px; }
  .bar-addr { font-size: 12px; color: var(--ink-mid); width: 160px; flex-shrink: 0; line-height: 1.3; }
  .bar-addr small { font-size: 10px; color: var(--ink-light); display: block; }
  .bar-track { flex: 1; height: 28px; background: var(--sand-light); border-radius: 2px; position: relative; }
  .bar-fill { height: 100%; border-radius: 2px; position: relative; }
  .bar-fill.best { background: #4A6741; }
  .bar-fill.mid { background: var(--gulf); }
  .bar-fill.high { background: var(--sand-dark); }
  .bar-val { position: absolute; right: -62px; top: 50%; transform: translateY(-50%); font-size: 11px; font-weight: 500; color: var(--ink-mid); white-space: nowrap; }
  .chart-legend { display: flex; gap: 24px; margin-top: 28px; flex-wrap: wrap; }
  .legend-item { display: flex; align-items: center; gap: 8px; font-size: 11px; color: var(--ink-light); }
  .legend-dot { width: 10px; height: 10px; border-radius: 2px; }

  .summary-cards { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; margin-bottom: 32px; }
  .sum-card { background: var(--white); border: 1px solid var(--border); border-radius: 4px; padding: 20px; }
  .sum-card-label { font-size: 9px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--ink-light); margin-bottom: 8px; }
  .sum-card-val { font-family: 'Cormorant Garamond', serif; font-size: 28px; font-weight: 400; color: var(--gulf-deep); line-height: 1; margin-bottom: 4px; }
  .sum-card-sub { font-size: 10px; color: var(--ink-light); }

  .guide-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(420px, 1fr)); gap: 16px; }
  .guide-card { background: var(--white); border: 1px solid var(--border); border-radius: 4px; padding: 24px; }
  .guide-q { font-family: 'Cormorant Garamond', serif; font-size: 17px; font-weight: 500; font-style: italic; color: var(--gulf-deep); margin-bottom: 12px; line-height: 1.4; }
  .guide-a { font-size: 13px; font-weight: 300; color: var(--ink-mid); line-height: 1.75; }

  footer { background: var(--ink); padding: 60px; margin-top: 80px; }
  .footer-inner { max-width: 1400px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 60px; }
  .footer-brand h2 { font-family: 'Cormorant Garamond', serif; font-size: 28px; font-weight: 300; color: var(--white); line-height: 1.2; margin-bottom: 8px; }
  .footer-brand h2 em { font-style: italic; color: var(--gulf-light); }
  .footer-brand p { font-size: 12px; color: rgba(253,250,247,0.4); font-weight: 300; }
  .footer-contact h3, .footer-note h3 { font-size: 9px; font-weight: 500; letter-spacing: 0.18em; text-transform: uppercase; color: var(--gulf-light); margin-bottom: 20px; }
  .contact-item { display: flex; align-items: flex-start; gap: 14px; margin-bottom: 16px; }
  .contact-icon { width: 32px; height: 32px; border: 1px solid rgba(74,124,142,0.35); border-radius: 2px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
  .contact-icon svg { width: 14px; height: 14px; stroke: var(--gulf-light); fill: none; stroke-width: 1.5; }
  .contact-label { font-size: 9px; color: rgba(253,250,247,0.35); letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 2px; }
  .contact-value { font-size: 14px; color: var(--white); font-weight: 300; }
  .contact-value a { color: var(--white); text-decoration: none; }
  .contact-value a:hover { color: var(--gulf-light); }
  .footer-note p { font-size: 12px; color: rgba(253,250,247,0.35); font-weight: 300; line-height: 1.7; }
  .footer-bottom { max-width: 1400px; margin: 40px auto 0; padding-top: 24px; border-top: 1px solid rgba(255,255,255,0.08); display: flex; justify-content: space-between; font-size: 10px; color: rgba(253,250,247,0.25); letter-spacing: 0.06em; flex-wrap: wrap; gap: 8px; }

  @media (max-width: 900px) {
    .header-content, nav, main { padding-left: 24px; padding-right: 24px; }
    footer { padding: 40px 24px; }
    .footer-inner { grid-template-columns: 1fr; gap: 32px; }
    .summary-cards { grid-template-columns: 1fr 1fr; }
    .guide-grid { grid-template-columns: 1fr; }
    .bar-addr { width: 110px; }
  }
  @media (max-width: 600px) {
    .nav-tab { padding: 0 10px; font-size: 10px; }
    .nav-realtor { display: none; }
    .summary-cards { grid-template-columns: 1fr 1fr; }
  }

  @keyframes fadeUp { from { opacity: 0; transform: translateY(16px); } to { opacity: 1; transform: translateY(0); } }
  .prop-card { animation: fadeUp 0.4s ease forwards; opacity: 0; }
  .prop-card:nth-child(1) { animation-delay: 0.05s; }
  .prop-card:nth-child(2) { animation-delay: 0.10s; }
  .prop-card:nth-child(3) { animation-delay: 0.15s; }
  .prop-card:nth-child(4) { animation-delay: 0.20s; }
  .prop-card:nth-child(5) { animation-delay: 0.25s; }
  .guide-card { animation: fadeUp 0.4s ease forwards; opacity: 0; }
  .guide-card:nth-child(1) { animation-delay: 0.05s; }
  .guide-card:nth-child(2) { animation-delay: 0.10s; }
  .guide-card:nth-child(3) { animation-delay: 0.15s; }
  .guide-card:nth-child(4) { animation-delay: 0.20s; }
  .guide-card:nth-child(5) { animation-delay: 0.25s; }
  .guide-card:nth-child(6) { animation-delay: 0.30s; }
</style>
</head>
